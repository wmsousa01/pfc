# =====================================================================
# Fora da Caixa — variáveis de ambiente
# Copie para .env.local e preencha. Reinicie o `npm run dev` depois.
# =====================================================================

# --- Supabase (parceiros, tracking, destaques IG, login do admin) ---
# Painel Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# NUNCA exponha esta chave no client. Só no servidor.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# --- YouTube (opcional) ---
# O channel_id do canal já está embutido no código. Só defina para trocar.
# YOUTUBE_CHANNEL_ID=UCskyIZf6RflDfhUjYZ865Jw

# --- Site (opcional) ---
# Usado como fallback para gerar URLs absolutas de QR fora de uma request.
# NEXT_PUBLIC_SITE_URL=https://foradacaixa.com.br
